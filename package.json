{
  "name": "brain",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "bun run src/index.ts",
    "stop": "launchctl stop com.rahilsinghi.brain 2>/dev/null || kill $(cat .brain/daemon.pid) 2>/dev/null || true",
    "status": "launchctl list com.rahilsinghi.brain 2>/dev/null && echo 'managed by launchd' || (kill -0 $(cat .brain/daemon.pid) 2>/dev/null && echo 'running (manual)' || echo 'stopped')",
    "restart": "launchctl stop com.rahilsinghi.brain && sleep 1 && launchctl start com.rahilsinghi.brain",
    "logs": "tail -f .brain/daemon.stdout.log",
    "logs:err": "tail -f .brain/daemon.stderr.log",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/seed/index.ts",
    "seed:tracking": "tsx src/seed/index.ts --only tracking",
    "seed:github": "tsx src/seed/index.ts --only github",
    "seed:git-commits": "bun run src/seed/index.ts --only git-commits",
    "gmail:auth": "tsx scripts/gmail-auth.ts",
    "calendar:auth": "tsx scripts/calendar-auth.ts",
    "slack:auth": "bun run scripts/slack-auth.ts",
    "backfill-links": "bun run src/graph/backfill-links.ts",
    "backfill-links:dry": "bun run src/graph/backfill-links.ts --dry-run",
    "graphify": "bun run src/cli/graphify.ts",
    "timesheet": "bun run src/cli/timesheet.ts",
    "brain-connect": "bash scripts/brain-connect.sh",
    "ts:add": "bun run src/cli/timesheet-add.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google-cloud/vertexai": "^1.11.0",
    "@google/generative-ai": "^0.24.1",
    "@lancedb/lancedb": "^0.27.2",
    "@slack/web-api": "^7.15.1",
    "@types/minimatch": "^6.0.0",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "csv-parse": "^6.2.1",
    "fastify": "^5.8.4",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "minimatch": "^10.2.5",
    "node-cron": "^4.2.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "turndown": "^7.2.4",
    "umap-js": "^1.4.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "protobufjs",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.6",
    "bun-types": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}